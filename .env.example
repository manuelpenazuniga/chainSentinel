# ============================================
# ChainSentinel Environment Variables
# ============================================
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# --- Blockchain ---
RPC_URL=https://services.polkadothub-rpc.com/testnet
WS_URL=wss://services.polkadothub-rpc.com/testnet
CHAIN_ID=420420417

# The private key of the AI agent wallet (guardian)
# This wallet must be funded with PAS for gas fees
# Generate with: cast wallet new
AGENT_PRIVATE_KEY=0x...

# Deployed contract addresses (fill after deployment)
VAULT_ADDRESS=0x...
REGISTRY_ADDRESS=0x...

# --- Dual-VM (optional) ---
# PVM vault/registry addresses for simultaneous REVM+PVM monitoring.
# When set, the agent executes emergency withdrawals on BOTH vaults.
# VAULT_ADDRESS_PVM=0x...
# REGISTRY_ADDRESS_PVM=0x...

# --- AI ---
# Google Gemini API key (get free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# --- Notifications ---
# Telegram Bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram chat ID to send alerts to
TELEGRAM_CHAT_ID=

# --- Heartbeat (optional) ---
# SentinelHeartbeat contract address — agent pings every N blocks to prove liveness
# HEARTBEAT_ADDRESS=0x...
# Blocks between heartbeat pings (default: 50 ~= 5 min at 6s/block)
# HEARTBEAT_INTERVAL_BLOCKS=50

# --- Agent Configuration ---
# Minimum heuristic score to trigger LLM analysis (0-100)
HEURISTIC_THRESHOLD=30
# Minimum final score to trigger emergency withdraw (0-100)
# Use 50 for demo/hackathon mode, 80 for production.
# Remember to also update the on-chain vault threshold via setThreshold().
DEFAULT_EMERGENCY_THRESHOLD=80
# Blocks to wait between emergency withdrawals
COOLDOWN_BLOCKS=10
# Maximum seconds to wait for LLM response before falling back to heuristics
LLM_TIMEOUT_MS=30000
